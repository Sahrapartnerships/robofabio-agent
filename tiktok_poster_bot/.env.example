# TikTok environment configuration
# Copy this file to .env and customize

# ============================================
# Browser Settings
# ============================================

# Run browser in headless mode (no visible window)
# Set to 'false' for debugging
TIKTOK_HEADLESS=false

# Browser type: chromium, firefox, webkit
TIKTOK_BROWSER=chromium

# Slow motion delay in milliseconds (for debugging)
# Set to 0 to disable, 1000 for 1 second delay between actions
TIKTOK_SLOW_MO=0

# ============================================
# Timeouts (in milliseconds)
# ============================================

TIKTOK_TIMEOUT=30000
TIKTOK_NAV_TIMEOUT=60000
TIKTOK_UPLOAD_TIMEOUT=300000

# ============================================
# Retry Settings
# ============================================

TIKTOK_MAX_RETRIES=3
TIKTOK_RETRY_DELAY=5

# ============================================
# Delays (in seconds)
# ============================================

# Delay between actions
TIKTOK_DELAY_MIN=2
TIKTOK_DELAY_MAX=5

# Typing delay (seconds per character)
TIKTOK_TYPING_MIN=0.05
TIKTOK_TYPING_MAX=0.15

# ============================================
# Session Settings
# ============================================

# Session expiry in days
TIKTOK_SESSION_EXPIRY=7

# ============================================
# Feature Flags
# ============================================

# Use stealth mode to avoid detection
TIKTOK_STEALTH=true

# Save screenshots for debugging
TIKTOK_SCREENSHOTS=true

# Enable debug mode (verbose logging)
TIKTOK_DEBUG=false

# Enable scheduler
TIKTOK_SCHEDULER=false

# ============================================
# Logging
# ============================================

TIKTOK_LOG_LEVEL=INFO

# ============================================
# Optional: Credentials (use with caution!)
# ============================================
# It's recommended to use manual login instead
# of storing credentials in environment variables

# TIKTOK_USERNAME=your_username
# TIKTOK_PASSWORD=your_password
# TIKTOK_EMAIL=your_email@example.com
